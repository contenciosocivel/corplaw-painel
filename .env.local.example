# ============================================================
# CORPLAW — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA suba o .env.local para o Git
# ============================================================

# Token Bearer da API ADVBOX
# Obtido em: Configurações > Integrações e API
ADVBOX_TOKEN=seu_token_aqui

# Senha de acesso ao painel (para todas as pessoas do escritório)
# Troque por uma senha forte
PAINEL_PASSWORD=senha_do_escritorio

# Segredo para criptografar a sessão (gere uma string aleatória de 32+ caracteres)
SESSION_SECRET=gere_uma_string_aleatoria_aqui_minimo_32_chars
